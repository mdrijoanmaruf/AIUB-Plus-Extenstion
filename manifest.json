{
  "manifest_version": 3,
  "name": "AIUB Portal+",
  "short_name": "AIUB+",
  "description": "Enhance the AIUB Student Portal with course filters, clash detection, grade analytics, schedule tools, and UI improvements.",
  "version": "2.0.0",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["https://portal.aiub.edu/*", "https://aiub.edu/*"],
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "logo/icon16.png",
      "48": "logo/icon48.png",
      "128": "logo/icon128.png"
    }
  },
  "icons": {
    "16": "logo/icon16.png",
    "48": "logo/icon48.png",
    "128": "logo/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://portal.aiub.edu/Student*"],
      "js": ["src/components/shared/contentBridge.jsx"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://portal.aiub.edu/Student*"],
      "js": [
        "src/components/shared/Sidebar.jsx",
        "src/components/shared/Navbar.jsx"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://portal.aiub.edu/Student",
        "https://portal.aiub.edu/Student/",
        "https://portal.aiub.edu/Student/Home/*"
      ],
      "js": [
        "src/components/home/Intro.jsx",
        "src/components/home/ClassSchedule.jsx",
        "src/components/home/HomeRegistration.jsx"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Section?*"],
      "js": ["src/components/academic/SectionDetails.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Section/Offered*"],
      "js": ["src/components/content/OfferedFilters.jsx"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Course?*"],
      "js": ["src/components/academic/CourseAndResults.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Registration?*"],
      "js": ["src/components/academic/AcademicRegistration.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Curriculum*"],
      "js": ["src/components/academic/MkCurriculumn.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Accounts*"],
      "js": ["src/components/academic/Financials.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Adrop/DropApplication*"],
      "js": ["src/components/academic/DropApplication.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/ExamRoutineSchedule*"],
      "js": ["src/components/academic/ExamRoutine.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/GradeReport/ByCurriculum*"],
      "js": ["src/components/grade/carriculum_grade_report.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/GradeReport/BySemester*"],
      "js": ["src/components/grade/carriculum_grade_semester.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Home/Profile*"],
      "js": ["src/components/content/ProfileContent.jsx"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "logo/icon16.png",
        "logo/icon48.png",
        "logo/icon128.png",
        "logo/logo128.png",
        "Academic/CSE.json"
      ],
      "matches": ["https://portal.aiub.edu/*"]
    }
  ]
}
