{
  "manifest_version": 3,
  "name": "AIUB Portal+",
  "short_name": "AIUB+",
  "description": "Enhance the AIUB Student Portal with course filters, clash detection, grade analytics, schedule tools, and UI improvements.",
  "version": "2.0.0",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["https://portal.aiub.edu/*"],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "logo/icon16.png",
      "48": "logo/icon48.png",
      "128": "logo/icon128.png"
    }
  },
  "icons": {
    "16": "logo/icon16.png",
    "48": "logo/icon48.png",
    "128": "logo/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://portal.aiub.edu/Student*"],
      "js": ["src/components/entries/sharedBridge.content.jsx"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://portal.aiub.edu/Student*"],
      "js": ["src/components/entries/sharedSidebar.content.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://portal.aiub.edu/Student",
        "https://portal.aiub.edu/Student/",
        "https://portal.aiub.edu/Student/Home/*"
      ],
      "js": ["src/components/entries/homeBundle.content.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Section/Offered*"],
      "js": ["src/components/entries/offeredFilters.content.jsx"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Course?*"],
      "js": ["src/components/entries/academicCourseResults.content.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Registration?*"],
      "js": ["src/components/entries/academicRegistration.content.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Curriculum*"],
      "js": ["src/components/entries/academicCurriculum.content.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Accounts*"],
      "js": ["src/components/entries/academicFinancials.content.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Adrop/DropApplication*"],
      "js": ["src/components/entries/academicDropApplication.content.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/ExamRoutineSchedule*"],
      "js": ["src/components/entries/academicExamRoutine.content.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/GradeReport/ByCurriculum*"],
      "js": ["src/components/entries/gradeCurriculum.content.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/GradeReport/BySemester*"],
      "js": ["src/components/entries/gradeSemester.content.jsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.aiub.edu/Student/Home/Profile*"],
      "js": ["src/components/entries/profileContent.content.jsx"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "logo/icon16.png",
        "logo/icon48.png",
        "logo/icon128.png",
        "logo/logo128.png",
        "Academic/CSE.json"
      ],
      "matches": ["https://portal.aiub.edu/*"]
    }
  ]
}
